books = ["Math", "English", "Science"]
borrowed = []

while True:
    print("\n1. Show books")
    print("2. Borrow book")
    print("3. Return book")
    print("4. Exit")

    c = input("Chagua: ")

    match c:

        case "1":
            print("Available books:")
            for b in books:
                print(b)

        case "2":
            student = input("Student name: ")
            book = input("Book name: ")

            if book in books:
                books.remove(book)
                borrowed.append((student, book))
                print(student, "borrowed", book)
            else:
                print("Book not available")

        case "3":
            student = input("Student name: ")
            book = input("Book name: ")

            if (student, book) in borrowed:
                borrowed.remove((student, book))
                books.append(book)
                print(student, "returned", book)
            else:
                print("Record not found")

        case "4":
            break

        case _:
            print("Wrong choice")
